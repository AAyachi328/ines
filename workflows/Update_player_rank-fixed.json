    {
      "parameters": {
        "jsCode": "const html = $json.rows || [];\nreturn html.map((row, index) => {\n  const rankMatch = row.match(/<td[^>]*class=\"rank-cell[^\"]*\"[^>]*>\\s*<span[^>]*>(\\d+)<\\/span>/i);\n  const playerMatch = row.match(/<a[^>]*href=\"[^\"]*\/player\/[^\"]*\"[^>]*>([^<]+)<\\/a>/i);\n  const pointsMatch = row.match(/<td[^>]*class=\"points-cell[^\"]*\"[^>]*>.*?<span[^>]*>([\\d,]+)<\\/span>/is);\n  return {\n    json: {\n      rank: rankMatch ? Number(rankMatch[1]) : index + 1,\n      player: playerMatch ? playerMatch[1].trim() : null,\n      points: pointsMatch ? Number(pointsMatch[1].replace(/,/g, '')) : null,\n      wikipediaUrl: playerMatch ? `https://en.wikipedia.org/wiki/${playerMatch[1].trim().replace(/\\s+/g, '_')}` : null\n    }\n  };\n}).filter(item => item.json.player);"
      },
