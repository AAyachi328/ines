    {
      "parameters": {
        "jsCode": "const html = $json || {};\nconst source = html.data || html.html || html.content || JSON.stringify(html);\n\nfunction pick(regex) {\n  const m = source.match(regex);\n  return m ? m[1] : null;\n}\n\nlet imageUrl = pick(/<meta[^>]+property=\"og:image\"[^>]+content=\"([^\"]+)\"/i)\n  || pick(/<table[^>]*class=\"[^\"]*infobox[^\"]*\"[\\s\\S]*?<img[^>]+src=\"([^\"]+)\"/i)\n  || pick(/<img[^>]+src=\"([^\"]+)\"[^>]*>/i);\n\nif (imageUrl) {\n  if (imageUrl.startsWith('//')) imageUrl = 'https:' + imageUrl;\n  if (imageUrl.startsWith('/')) imageUrl = 'https://en.wikipedia.org' + imageUrl;\n  imageUrl = imageUrl.replace(/\\/thumb(\\/[^?]+?)\\/[^/]+$/, '$1');\n}\n\nreturn [{ json: { ...$json, imageUrl } }];"
      },
